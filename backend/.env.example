# Pocket Backend
POCKET_ENV=development
POCKET_DB_PATH=~/.pocket/pocket.db
POCKET_LOG_LEVEL=INFO
POCKET_HOST=0.0.0.0
POCKET_PORT=8000
POCKET_CORS_ORIGINS=http://localhost:3000

# Azure OpenAI (NEVER commit real keys)
POCKET_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
POCKET_AZURE_OPENAI_API_KEY=your-api-key-here
POCKET_AZURE_OPENAI_API_VERSION=2024-12-01-preview
POCKET_AZURE_OPENAI_DEPLOYMENT_CHAT=gpt-4.1
POCKET_AZURE_OPENAI_DEPLOYMENT_CHAT_MINI=gpt-4.1-mini
POCKET_AZURE_OPENAI_DEPLOYMENT_EMBEDDING=text-embedding-3-large

# Embedding
POCKET_EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
POCKET_EMBEDDING_DIMENSIONS=384

# Features
POCKET_AUTO_EMBED=true
POCKET_AUTO_TAG=true
POCKET_LEARNING_ENABLED=true
